# Copy to .env and fill in real values. .env is gitignored — never commit it.
#
# Where each value is used:
#   - docker compose interpolates ${VAR} in kometa-compose.yml / aura-compose.yml
#     (compose auto-loads the .env sitting next to the compose file)
#   - the kometa service maps these into KOMETA_* "Config Secrets" that
#     config.yml references as <<secretname>> placeholders
#     (secret names must not contain underscores or the word PLEX — Kometa quirks)
#   - render-aura-configs.py substitutes ${VAR} in aura-configs/*/config.yaml.template

# Plex token used by Kometa + the ImageMaids (works on every server you own)
PLEX_TOKEN=

# AURA's own Plex token for the main (curation) server
AURA_PLEX_TOKEN=

# MediUX API token (mediux.pro → user settings)
MEDIUX_TOKEN=

# TMDb API key — also powers the exporter's TMDb→TVDb fallback for shows
# whose file paths lack a {tvdb-NNN} tag (common with anime)
TMDB_APIKEY=

# Optional: Discord webhook for Kometa notifications
DISCORD_WEBHOOK=

# Optional: Radarr / Sonarr API keys (only if config.yml uses them)
RADARR_TOKEN=
SONARR_TOKEN=

# Optional: Trakt app + seed tokens (Kometa refreshes them in the deployed
# config.yml afterwards — these only matter on first deploy)
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_ACCESS_TOKEN=
TRAKT_REFRESH_TOKEN=
